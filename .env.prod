DB_URL=jdbc:postgresql://auth-db:5432/auth_db
DB_USER=auth
DB_PASSWORD=auth

JWT_SECRET=change-me-in-production-use-long-random-secret-key-256bits
JWT_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=604800

CORS_ORIGINS=http://localhost:8081,http://localhost:3000,http://localhost:5173

SECURITY_HSTS_ENABLED=true
LOGIN_RATE_LIMIT=30

JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false